[URL Rewrite]
^https:\/\/api\.pinterest\.com\/v\d\/feeds\/home\/\? response-body-json-jq '.data |= map(select(.is_promoted == false or .is_promoted == "false"))'

^https:\/\/api\.pinterest\.com\/v\d\/pins\/\d+\/related\/modules\/\? response-body-json-jq '.data |= map(select(.is_promoted == false or .is_promoted == "false"))'

[MITM]
hostname = %APPEND% api.pinterest.com
