#!name=HTTPDNS拦截器 - Surge
#!desc=拦截常见的HTTPDNS服务，以确保这些请求都能够在Loon的DNS框架下工作。；由 Loon 插件自动转换为 Surge 模块，建议导入前抽查。
#!homepage=https://kelee.one/Tool/Loon/Lpx/Block_HTTPDNS.lpx
#!system=ios
#!openUrl=
#!author=可莉🅥[https://github.com/luestr/ProxyResource/blob/main/README.md], VirgilClyne[https://github.com/VirgilClyne]
#!tag=去广告, 依赖
#!system=
#!system_version=
#!homepage=https://hub.kelee.one
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/Other_icon/120px/HTTPDNS.png
#!date=2026-06-15 21:46:05

[Rule]
DOMAIN-KEYWORD, httpdns, REJECT
DOMAIN-KEYWORD, httpsdns, REJECT

USER-AGENT, "httpdns*", REJECT
USER-AGENT, "httpsdns*", REJECT
USER-AGENT, "Httpdns*", REJECT
USER-AGENT, "Httpsdns*", REJECT


URL-REGEX, "^http:\/\/((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)(?:\/v?[0-9]+)?\/(?:sign_)?(?:(?:d|ss)[46]?|resolve)\?", REJECT


URL-REGEX, "^http:\/\/\[[0-9a-fA-F:]+\](?:\/v?[0-9]+)?\/(?:sign_)?(?:(?:d|ss)[46]?|resolve)\?", REJECT

DOMAIN, yyapp-httpdns.gslb.yy.com, REJECT
DOMAIN, union-httpdns.gslb.yy.com, REJECT
DOMAIN, yuyin-httpdns.gslb.yy.com, REJECT
DOMAIN, httpdns-v6.gslb.yy.com, REJECT

URL-REGEX, "^http:\/\/103\.44\.58\.64\/md\?", REJECT

URL-REGEX, "^http:\/\/cdn\.wup\.huya\.com\/launch\/queryHttpDns", REJECT

DOMAIN, dns2.q2cdn.com, REJECT
URL-REGEX, "^http:\/\/xmc\.ximalaya\.com\/xmlymain-login-web\/login\/", REJECT


DOMAIN, dns.weixin.qq.com, REJECT
DOMAIN, dns.weixin.qq.com.cn, REJECT
