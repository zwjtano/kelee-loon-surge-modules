#!name=自动加入TestFlight - Surge
#!desc=自动监控TestFlight名额，一旦有新的名额即刻加入。；由 Loon 插件自动转换为 Surge 模块，建议导入前抽查。
#!homepage=https://kelee.one/Tool/Loon/Lpx/Auto_Join_TF.lpx
#!system=ios
#!openUrl=https://apps.apple.com/app/id899247664
#!author=奶思[https://github.com/fmz200], DecoAri[https://github.com/DecoAri], xream[https://github.com/xream]
#!tag=定时任务
#!system=
#!system_version=
#!homepage=https://hub.kelee.one
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/TestFlight.png
#!input=App_ID
#!date=2026-06-01 17:11:35
#!arguments=CaptureAccountToken:false,RunTask:false,RunMonitor:true,TaskCron:"0 0/2 * * * ?",TaskMonitor:"0 * * * * ?"

[Script]
获取账号令牌 = type=http-request, pattern=^https?:\/\/testflight\.apple\.com\/v3\/accounts\/.*\/apps$, script-path=https://kelee.one/Resource/JavaScript/TestFlight/CaptureAccountToken.js, enable={{{CaptureAccountToken}}}
自动加入TF = type=cron, cronexp={{{TaskCron}}}, script-path=https://kelee.one/Resource/JavaScript/TestFlight/AutoJoinTF.js, timeout=600, enable={{{RunTask}}}
监控TF位置 = type=cron, cronexp={{{TaskMonitor}}}, script-path=https://kelee.one/Resource/JavaScript/TestFlight/AutoMonitorTF.js, timeout=30, enable={{{RunMonitor}}}
