#!name=Apple天气增强 - Surge
#!desc=解锁Apple天气的全部功能、替换空气质量数据源、添加下一小时降水数据、添加天气数据。；由 Loon 插件自动转换为 Surge 模块，建议导入前抽查。
#!homepage=https://kelee.one/Tool/Loon/Lpx/AppleWeatherEnhancer.lpx
#!system=ios
#!openUrl=https://itunes.apple.com/app/id1069513131
#!author=VirgilClyne[https://github.com/VirgilClyne], WordlessEcho[https://github.com/WordlessEcho], 001[https://github.com/001ProMax]
#!tag=功能增强
#!system=iOS, iPadOS, macOS, watchOS
#!system_version=18
#!homepage=https://hub.kelee.one
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/AppleWeather.png
#!date=2026-06-01 17:11:35
#!arguments=Weather.Provider:"ColorfulClouds",NextHour.Provider:"ColorfulClouds",AirQuality.Calculate.Algorithm:"EU_EAQI",API.ColorfulClouds.Token:"tag",API.QWeather.Host:"devapi.qweather.com",API.QWeather.Token:"tag",API.WAQI.Token:"tag",Storage:"Argument",LogLevel:"WARN"
#!category=zwjtano

[Script]
天气可用性响应 = type=http-response, pattern=^https?:\/\/weatherkit\.apple\.com\/api\/v1\/availability\/, script-path=https://github.com/NSRingo/WeatherKit/releases/download/v3.1.0/response.bundle.js, requires-body=true, argument=[{Weather.Provider}, {NextHour.Provider}, {AirQuality.Calculate.Algorithm}, {API.ColorfulClouds.Token}, {API.QWeather.Host}, {API.QWeather.Token}, {API.WAQI.Token}, {{{Storage}}}, {{{LogLevel}}}]

天气响应 = type=http-response, pattern=^https?:\/\/weatherkit\.apple\.com\/api\/v2\/weather\/, script-path=https://github.com/NSRingo/WeatherKit/releases/download/v3.1.0/response.bundle.js, requires-body=true, binary-body-mode=true, argument=[{Weather.Provider}, {NextHour.Provider}, {AirQuality.Calculate.Algorithm}, {API.ColorfulClouds.Token}, {API.QWeather.Host}, {API.QWeather.Token}, {API.WAQI.Token}, {{{Storage}}}, {{{LogLevel}}}]

[MITM]
hostname = %APPEND% weatherkit.apple.com
